load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

package(default_visibility = [
    "//graft/coreth:__subpackages__",
    "//graft/coreth:external_consumers",
])


go_library(
    name = "main_lib",
    srcs = ["main.go"],
    importpath = "github.com/ava-labs/avalanchego/graft/coreth/cmd/simulator/main",
    visibility = ["//visibility:private"],
    deps = [
        "//graft/coreth/cmd/simulator/config",
        "//graft/coreth/cmd/simulator/load",
        "//graft/evm/log",
        "@com_github_ava_labs_libevm//log",
        "@com_github_spf13_pflag//:pflag",
    ],
)

go_binary(
    name = "main",
    embed = [":main_lib"],
)
