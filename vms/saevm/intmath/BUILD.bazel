load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("//.bazel:defs.bzl", "go_test")

go_library(
    name = "intmath",
    srcs = ["intmath.go"],
    importpath = "github.com/ava-labs/avalanchego/vms/saevm/intmath",
    visibility = ["//visibility:public"],
