load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("//.bazel:defs.bzl", "go_test")

go_library(
    name = "txgossip",
    srcs = [
        "blockchain.go",
        "priority.go",
        "pushpull.go",
        "txgossip.go",
