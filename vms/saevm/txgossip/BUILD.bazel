    importpath = "github.com/ava-labs/avalanchego/vms/saevm/txgossip",
    visibility = ["//visibility:public"],
    deps = [
        "//ids",
        "//network/p2p/gossip",
        "//utils/logging",
        "//vms/saevm/saexec",
        "//vms/saevm/types",
        "@com_github_ava_labs_libevm//common",
