load("@io_bazel_rules_go//go:def.bzl", "go_library")
load("//.bazel:defs.bzl", "go_test")

go_library(
    name = "saetest",
    srcs = [
        "heightdb.go",
        "logging.go",
        "saetest.go",
        "wallet.go",
    ],
    importpath = "github.com/ava-labs/avalanchego/vms/saevm/saetest",
    visibility = ["//visibility:public"],
    deps = [
        "//database",
        "//utils/lock",
        "//utils/logging",
        "//vms/saevm/saedb",
        "//vms/saevm/types",
        "@com_github_ava_labs_libevm//common",
        "@com_github_ava_labs_libevm//core/state",
        "@com_github_ava_labs_libevm//core/state/snapshot",
        "@com_github_ava_labs_libevm//core/types",
        "@com_github_ava_labs_libevm//crypto",
        "@com_github_ava_labs_libevm//event",
        "@com_github_ava_labs_libevm//libevm/ethtest",
        "@com_github_ava_labs_libevm//params",
        "@com_github_ava_labs_libevm//trie",
        "@com_github_holiman_uint256//:uint256",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_zap//:zap",
        "@org_uber_go_zap//zapcore",
    ],
)

go_test(
    name = "saetest_test",
    srcs = ["saetest_test.go"],
    embed = [":saetest"],
    deps = [
        "@com_github_ava_labs_libevm//event",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_goleak//:goleak",
    ],
)
