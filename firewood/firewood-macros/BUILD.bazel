# gazelle:ignore

load("@firewood_crates//:defs.bzl", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_proc_macro")

rust_proc_macro(
    name = "firewood-macros",
    srcs = glob(["src/**/*.rs"]),
    crate_root = "src/lib.rs",
    edition = "2024",
    visibility = ["//firewood:__subpackages__"],
    deps = all_crate_deps(package_name = "firewood/firewood-macros"),
)
